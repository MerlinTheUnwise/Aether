{
  "id": "multi_agent_marketplace",
  "version": 1,
  "effects": ["database.read", "database.write", "payment_gateway.write", "shipping.write", "email", "analytics.write", "notification"],
  "metadata": {
    "description": "Multi-agent marketplace: 4 scopes (seller, buyer, payment, logistics) with complex boundary contracts",
    "safety_level": "high",
    "human_oversight": { "required_when": "confidence < 0.85" }
  },
  "nodes": [
    {
      "id": "list_product",
      "in": {
        "seller_id": { "type": "String", "domain": "seller", "sensitivity": "pii" },
        "product_data": { "type": "Map<String,String>", "domain": "catalog" }
      },
      "out": {
        "listing_id": { "type": "String", "domain": "catalog" },
        "listing_price": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "axioms": ["listing_id.length > 0", "listing_price > 0"],
      "contract": {
        "pre": ["product_data.length > 0"],
        "post": ["listing_id.length > 0", "listing_price > 0"]
      },
      "effects": ["database.write"],
      "recovery": {
        "db_error": { "action": "retry", "params": { "count": 3, "backoff": "exponential" } }
      }
    },
    {
      "id": "verify_seller",
      "in": {
        "seller_id": { "type": "String", "domain": "seller", "sensitivity": "pii" }
      },
      "out": {
        "seller_verified": { "type": "Bool" },
        "seller_rating": { "type": "Float64", "domain": "reputation" }
      },
      "axioms": ["seller_verified = true"],
      "contract": {
        "post": ["seller_verified == true"]
      },
      "confidence": 0.80,
      "adversarial_check": {
        "break_if": ["seller_rating < 0", "seller_rating > 5"]
      },
      "effects": ["database.read"],
      "recovery": {
        "verification_timeout": { "action": "retry", "params": { "count": 2 } }
      },
      "supervised": {
        "reason": "Seller verification involves trust assessment — requires human review for new sellers"
      }
    },
    {
      "id": "calculate_fees",
      "in": {
        "listing_price": { "type": "Float64", "dimension": "currency", "unit": "USD" },
        "seller_rating": { "type": "Float64", "domain": "reputation" }
      },
      "out": {
        "platform_fee": { "type": "Float64", "dimension": "currency", "unit": "USD" },
        "seller_payout": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "axioms": ["platform_fee >= 0", "seller_payout >= 0", "platform_fee + seller_payout = listing_price"],
      "contract": {
        "pre": ["listing_price > 0"],
        "post": ["platform_fee >= 0", "seller_payout >= 0", "platform_fee + seller_payout == listing_price"]
      },
      "pure": true,
      "effects": []
    },
    {
      "id": "browse_catalog",
      "in": {
        "search_query": { "type": "String", "domain": "catalog" }
      },
      "out": {
        "search_results": { "type": "List<Listing>", "domain": "catalog" },
        "result_count": { "type": "Int" },
        "selected_listing": { "type": "String", "domain": "catalog" }
      },
      "axioms": ["result_count >= 0"],
      "contract": {
        "post": ["result_count >= 0"]
      },
      "effects": ["database.read"],
      "recovery": {
        "search_error": { "action": "fallback", "params": { "value": [] } }
      }
    },
    {
      "id": "place_order",
      "in": {
        "listing_id": { "type": "String", "domain": "catalog" },
        "buyer_id": { "type": "String", "domain": "buyer", "sensitivity": "pii" },
        "listing_price": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "out": {
        "order_id": { "type": "String", "domain": "order" },
        "order_total": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "axioms": ["order_id.length > 0", "order_total > 0"],
      "contract": {
        "pre": ["listing_id.length > 0", "listing_price > 0"],
        "post": ["order_id.length > 0", "order_total > 0"]
      },
      "effects": ["database.write"],
      "recovery": {
        "order_failed": { "action": "respond", "params": { "status": 500, "body": "order creation failed" } }
      }
    },
    {
      "id": "buyer_review",
      "in": {
        "order_id": { "type": "String", "domain": "order" },
        "buyer_id": { "type": "String", "domain": "buyer", "sensitivity": "pii" }
      },
      "out": {
        "review_submitted": { "type": "Bool" },
        "buyer_satisfaction": { "type": "Float64", "domain": "reputation" }
      },
      "axioms": ["review_submitted = true"],
      "contract": {
        "post": ["review_submitted == true"]
      },
      "effects": ["database.write"],
      "recovery": {
        "review_failed": { "action": "report", "params": { "channel": "review-failures" } }
      }
    },
    {
      "id": "process_marketplace_payment",
      "in": {
        "order_id": { "type": "String", "domain": "order" },
        "order_total": { "type": "Float64", "dimension": "currency", "unit": "USD" },
        "platform_fee": { "type": "Float64", "dimension": "currency", "unit": "USD" },
        "seller_payout": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "out": {
        "transaction_id": { "type": "String", "domain": "payment" },
        "payment_status": { "type": "String", "domain": "payment" }
      },
      "axioms": ["payment_status = completed", "transaction_id.length > 0"],
      "contract": {
        "pre": ["order_total > 0", "platform_fee >= 0", "seller_payout >= 0"],
        "post": ["payment_status == completed", "transaction_id.length > 0"]
      },
      "effects": ["payment_gateway.write"],
      "recovery": {
        "payment_declined": { "action": "respond", "params": { "status": 402, "body": "payment failed" } },
        "gateway_timeout": { "action": "retry", "params": { "count": 2, "backoff": "exponential" } }
      }
    },
    {
      "id": "escrow_hold",
      "in": {
        "transaction_id": { "type": "String", "domain": "payment" },
        "seller_payout": { "type": "Float64", "dimension": "currency", "unit": "USD" }
      },
      "out": {
        "escrow_id": { "type": "String", "domain": "payment" },
        "escrow_status": { "type": "String", "domain": "payment" }
      },
      "axioms": ["escrow_id.length > 0"],
      "contract": {
        "pre": ["transaction_id.length > 0", "seller_payout >= 0"],
        "post": ["escrow_id.length > 0"]
      },
      "confidence": 0.82,
      "adversarial_check": {
        "break_if": ["seller_payout < 0", "escrow_status == failed"]
      },
      "effects": ["payment_gateway.write", "database.write"],
      "recovery": {
        "escrow_failed": { "action": "escalate", "params": { "message": "escrow creation failed", "preserve_context": true } }
      }
    },
    {
      "id": "refund_check",
      "in": {
        "escrow_id": { "type": "String", "domain": "payment" },
        "buyer_satisfaction": { "type": "Float64", "domain": "reputation" }
      },
      "out": {
        "refund_eligible": { "type": "Bool" },
        "final_payment_status": { "type": "String", "domain": "payment" }
      },
      "axioms": ["final_payment_status.length > 0"],
      "contract": {
        "pre": ["escrow_id.length > 0"],
        "post": ["final_payment_status.length > 0"]
      },
      "pure": true,
      "effects": []
    },
    {
      "id": "create_shipment",
      "in": {
        "order_id": { "type": "String", "domain": "order" },
        "listing_id": { "type": "String", "domain": "catalog" },
        "transaction_id": { "type": "String", "domain": "payment" }
      },
      "out": {
        "tracking_number": { "type": "String", "domain": "fulfillment" },
        "estimated_delivery": { "type": "String", "domain": "fulfillment" }
      },
      "axioms": ["tracking_number.length > 0"],
      "contract": {
        "pre": ["order_id.length > 0", "transaction_id.length > 0"],
        "post": ["tracking_number.length > 0"]
      },
      "effects": ["shipping.write", "database.write"],
      "recovery": {
        "shipping_unavailable": { "action": "escalate", "params": { "message": "shipping service unavailable", "preserve_context": true } }
      }
    },
    {
      "id": "delivery_tracking",
      "in": {
        "tracking_number": { "type": "String", "domain": "fulfillment" },
        "order_id": { "type": "String", "domain": "order" }
      },
      "out": {
        "delivery_status": { "type": "String", "domain": "fulfillment" },
        "delivery_confirmed": { "type": "Bool" }
      },
      "axioms": ["delivery_status.length > 0"],
      "contract": {
        "post": ["delivery_status.length > 0"]
      },
      "effects": ["database.read", "notification"],
      "recovery": {
        "tracking_error": { "action": "retry", "params": { "count": 3, "backoff": "exponential" } }
      }
    },
    {
      "id": "notify_parties",
      "in": {
        "order_id": { "type": "String", "domain": "order" },
        "delivery_status": { "type": "String", "domain": "fulfillment" },
        "final_payment_status": { "type": "String", "domain": "payment" }
      },
      "out": {
        "notifications_sent": { "type": "Bool" }
      },
      "axioms": ["notifications_sent = true"],
      "contract": {
        "post": ["notifications_sent == true"]
      },
      "effects": ["email", "notification"],
      "recovery": {
        "notification_failed": { "action": "report", "params": { "channel": "notification-failures" } }
      }
    }
  ],
  "edges": [
    { "from": "list_product.listing_id", "to": "browse_catalog.search_query" },
    { "from": "list_product.listing_price", "to": "calculate_fees.listing_price" },
    { "from": "verify_seller.seller_rating", "to": "calculate_fees.seller_rating" },
    { "from": "browse_catalog.selected_listing", "to": "place_order.listing_id" },
    { "from": "list_product.listing_price", "to": "place_order.listing_price" },
    { "from": "place_order.order_id", "to": "buyer_review.order_id" },
    { "from": "place_order.order_id", "to": "process_marketplace_payment.order_id" },
    { "from": "place_order.order_total", "to": "process_marketplace_payment.order_total" },
    { "from": "calculate_fees.platform_fee", "to": "process_marketplace_payment.platform_fee" },
    { "from": "calculate_fees.seller_payout", "to": "process_marketplace_payment.seller_payout" },
    { "from": "process_marketplace_payment.transaction_id", "to": "escrow_hold.transaction_id" },
    { "from": "calculate_fees.seller_payout", "to": "escrow_hold.seller_payout" },
    { "from": "escrow_hold.escrow_id", "to": "refund_check.escrow_id" },
    { "from": "buyer_review.buyer_satisfaction", "to": "refund_check.buyer_satisfaction" },
    { "from": "place_order.order_id", "to": "create_shipment.order_id" },
    { "from": "list_product.listing_id", "to": "create_shipment.listing_id" },
    { "from": "process_marketplace_payment.transaction_id", "to": "create_shipment.transaction_id" },
    { "from": "create_shipment.tracking_number", "to": "delivery_tracking.tracking_number" },
    { "from": "place_order.order_id", "to": "delivery_tracking.order_id" },
    { "from": "place_order.order_id", "to": "notify_parties.order_id" },
    { "from": "delivery_tracking.delivery_status", "to": "notify_parties.delivery_status" },
    { "from": "refund_check.final_payment_status", "to": "notify_parties.final_payment_status" }
  ],
  "scopes": [
    {
      "id": "seller",
      "description": "Seller onboarding: listing, verification, and fee calculation",
      "nodes": ["list_product", "verify_seller", "calculate_fees"],
      "boundary_contracts": {
        "provides": [
          {
            "name": "listing_data",
            "in": {},
            "out": {
              "listing_id": { "type": "String", "domain": "catalog" },
              "listing_price": { "type": "Float64", "dimension": "currency", "unit": "USD" }
            },
            "effects": ["database.write", "database.read"],
            "confidence": 0.90
          },
          {
            "name": "fee_data",
            "in": {},
            "out": {
              "platform_fee": { "type": "Float64", "dimension": "currency", "unit": "USD" },
              "seller_payout": { "type": "Float64", "dimension": "currency", "unit": "USD" }
            }
          }
        ],
        "requires": []
      }
    },
    {
      "id": "buyer",
      "description": "Buyer experience: browsing, ordering, and reviews",
      "nodes": ["browse_catalog", "place_order", "buyer_review"],
      "boundary_contracts": {
        "requires": [
          {
            "name": "listing_data",
            "in": {
              "listing_id": { "type": "String", "domain": "catalog" },
              "listing_price": { "type": "Float64", "dimension": "currency", "unit": "USD" }
            },
            "out": {},
            "confidence": 0.85
          }
        ],
        "provides": [
          {
            "name": "order_data",
            "in": {},
            "out": {
              "order_id": { "type": "String", "domain": "order" },
              "order_total": { "type": "Float64", "dimension": "currency", "unit": "USD" },
              "buyer_satisfaction": { "type": "Float64", "domain": "reputation" }
            },
            "effects": ["database.write"],
            "confidence": 0.95
          }
        ]
      }
    },
    {
      "id": "payment",
      "description": "Payment processing: charging, escrow, and refund eligibility",
      "nodes": ["process_marketplace_payment", "escrow_hold", "refund_check"],
      "boundary_contracts": {
        "requires": [
          {
            "name": "order_data",
            "in": {
              "order_id": { "type": "String", "domain": "order" },
              "order_total": { "type": "Float64", "dimension": "currency", "unit": "USD" }
            },
            "out": {},
            "confidence": 0.9
          },
          {
            "name": "fee_data",
            "in": {
              "platform_fee": { "type": "Float64", "dimension": "currency", "unit": "USD" },
              "seller_payout": { "type": "Float64", "dimension": "currency", "unit": "USD" }
            },
            "out": {}
          },
          {
            "name": "order_data",
            "in": {
              "buyer_satisfaction": { "type": "Float64", "domain": "reputation" }
            },
            "out": {}
          }
        ],
        "provides": [
          {
            "name": "payment_result",
            "in": {},
            "out": {
              "transaction_id": { "type": "String", "domain": "payment" },
              "final_payment_status": { "type": "String", "domain": "payment" }
            },
            "effects": ["payment_gateway.write", "database.write"]
          }
        ]
      }
    },
    {
      "id": "logistics",
      "description": "Fulfillment: shipping, tracking, and notifications",
      "nodes": ["create_shipment", "delivery_tracking", "notify_parties"],
      "boundary_contracts": {
        "requires": [
          {
            "name": "order_data",
            "in": {
              "order_id": { "type": "String", "domain": "order" }
            },
            "out": {}
          },
          {
            "name": "listing_data",
            "in": {
              "listing_id": { "type": "String", "domain": "catalog" }
            },
            "out": {}
          },
          {
            "name": "payment_result",
            "in": {
              "transaction_id": { "type": "String", "domain": "payment" },
              "final_payment_status": { "type": "String", "domain": "payment" }
            },
            "out": {}
          }
        ],
        "provides": []
      }
    }
  ]
}
